{
  "name": "@stack/web",
  "private": true,
  "type": "module",
  "devSite": {
    "host": "stack.internal",
    "port": 3000
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "auth:login": "bun scripts/auth-login.mjs",
    "screenshots": "bun scripts/screenshot.mjs",
    "deploy": "bun run build && wrangler deploy --env prod",
    "deploy:dev": "bun run build && wrangler deploy --env dev"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@convex-dev/react-query": "^0.1.0",
    "@stack/api": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-router-ssr-query": "1.166.12",
    "@tanstack/react-start": "1.167.64",
    "@tanstack/router-plugin": "^1.132.0",
    "@workos/authkit-tanstack-react-start": "^0.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.37.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251104.0",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-router-devtools": "1.166.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.70.0"
  }
}
